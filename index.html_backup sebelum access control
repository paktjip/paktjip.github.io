<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PAKTJIP Digital Printing</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
 
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #a8c5a5 0%, #7fa87c 100%);
            min-height: 100vh;
            padding: 20px;
        }
 
        /* Saat konten terbuka: kunci scroll di body, biarkan iframe yang scroll */
        body.page-open {
            overflow: hidden;
            height: 100vh;
            padding: 0;
        }
        body.page-open #app {
            height: 100vh;
            max-width: 100%;
            margin: 0;
        }
        body.page-open #content-view {
            height: 100vh;
            border-radius: 0;
            box-shadow: none;
        }
 
        /* ── PASSWORD ── */
        .password-container {
            max-width: 400px;
            margin: 100px auto;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            overflow: hidden;
        }
        .password-header {
            background: linear-gradient(135deg, #6b8e6b 0%, #4a6f4a 100%);
            color: white;
            padding: 30px;
            text-align: center;
        }
        .password-header h2 { font-size: 1.8em; }
        .password-content { padding: 30px; }
        input[type="password"] {
            width: 100%;
            padding: 15px;
            border: 2px solid #ddd;
            border-radius: 8px;
            font-size: 1em;
            margin-bottom: 20px;
            transition: border-color 0.3s;
        }
        input[type="password"]:focus { outline: none; border-color: #7fa87c; }
        .password-button {
            background: linear-gradient(135deg, #4a6f4a 0%, #6b8e6b 100%);
            color: white;
            border: none;
            padding: 15px;
            font-size: 1.1em;
            font-weight: 600;
            border-radius: 8px;
            cursor: pointer;
            width: 100%;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(74,111,74,0.3);
        }
        .password-button:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(74,111,74,0.4); }
        .password-button:active { transform: translateY(0); }
        .error-message {
            color: #d32f2f;
            font-size: 0.9em;
            margin-top: -10px;
            margin-bottom: 15px;
            display: none;
            text-align: center;
            font-weight: 500;
        }
        .error-message.show { display: block; animation: shake 0.5s; }
 
        /* ── MAIN APP ── */
        #app { max-width: 900px; margin: 0 auto; display: none; }
        #app.show { display: block; animation: fadeIn 0.5s ease-out; }
 
        /* ── MENU VIEW ── */
        #menu-view {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            overflow: hidden;
        }
        .header {
            background: linear-gradient(135deg, #6b8e6b 0%, #4a6f4a 100%);
            color: white;
            padding: 40px 30px;
            text-align: center;
        }
        .header h1 { font-size: 2.2em; margin-bottom: 10px; }
        .content { padding: 40px 30px; }
        .links-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .menu-btn {
            background: linear-gradient(135deg, #4a6f4a 0%, #6b8e6b 100%);
            color: white;
            padding: 25px;
            border: none;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 15px;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(74,111,74,0.3);
            width: 100%;
            text-align: left;
        }
        .menu-btn:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(74,111,74,0.4); }
        .menu-btn:active { transform: translateY(-2px); }
        .menu-btn .emoji { font-size: 2.5em; flex-shrink: 0; }
        .menu-btn .text  { font-size: 1.1em; font-weight: 600; line-height: 1.4; }
        .coming-soon {
            text-align: center;
            padding: 30px;
            background: linear-gradient(135deg, #f4f9f4 0%, #e8f4e8 100%);
            border-radius: 12px;
            margin-bottom: 30px;
        }
        .coming-soon p { color: #4a6f4a; font-size: 1.2em; font-weight: 600; font-style: italic; }
        footer {
            text-align: center;
            padding: 25px;
            background: #f8f9f8;
            color: #666;
            font-size: 0.9em;
            line-height: 1.6;
        }
        footer strong { color: #4a6f4a; }
 
        /* ── CONTENT VIEW ── */
        #content-view {
            display: none;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            overflow: hidden;
        }
        #content-view.show { display: flex; flex-direction: column; animation: fadeIn 0.3s ease-out; }
        .content-topbar {
            background: linear-gradient(135deg, #6b8e6b 0%, #4a6f4a 100%);
            padding: 14px 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            flex-shrink: 0;
        }
        #back-btn {
            background: rgba(255,255,255,0.2);
            color: white;
            border: 2px solid rgba(255,255,255,0.5);
            border-radius: 8px;
            padding: 8px 18px;
            font-size: 0.95em;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s;
            white-space: nowrap;
            flex-shrink: 0;
        }
        #back-btn:hover { background: rgba(255,255,255,0.35); border-color: white; transform: translateX(-2px); }
        #page-title {
            color: white;
            font-size: 1.1em;
            font-weight: 600;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        /* Semua iframe tinggal di sini, show/hide via JS */
        #iframe-container {
            width: 100%;
            flex: 1;          /* ambil sisa tinggi setelah topbar */
            overflow-y: auto; /* scroll ada di sini, bukan di body */
        }
        #iframe-container iframe {
            width: 100%;
            height: 100%;
            border: none;
            display: block;
        }
 
        /* ── ANIMATIONS ── */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25%  { transform: translateX(-10px); }
            75%  { transform: translateX(10px); }
        }
 
        /* ── RESPONSIVE ── */
        @media (max-width: 768px) {
            .header h1 { font-size: 1.8em; }
            .links-grid { grid-template-columns: 1fr; }
            .menu-btn { padding: 20px; }
            .menu-btn .emoji { font-size: 2em; }
            .menu-btn .text  { font-size: 1em; }
        }
    </style>


    <script>
        /* ─── CONFIG: tambah fitur baru cukup di sini ─── */
        const MENU_ITEMS = [
            { emoji: "🔄️", label: "Konversi PDF ke Gambar",               file: "PDF2IMG.html" },
            {emoji: "📐", label: "Hitung Rasio Ukuran Cetak",            file: "Kalkulator_Ukuran_Cetak.html" },
            { emoji: "✂️", label: "Hitung Potongan Kertas",               file: "Hitung_Potong_Kertas.html" },
            { emoji: "📖", label: "Hitung Harga Buku",                    file: "Hitung_Harga_Buku_2026.html" },
            { emoji: "📕", label: "Hitung Ketebalan Punggung Buku",       file: "Hitung_Punggung_Buku.html" },
            { emoji: "🖼️", label: "Hitung Harga Spanram",                 file: "HargaSpanram_v2.html" },
            { emoji: "⚡", label: "Hitung Jasa Laser Cutting",            file: "Jasa_Laser_Cutting.html" },
            { emoji: "🔑", label: "Hitung Harga Gantungan Kunci Akrilik", file: "Hitung_Ganci_Akrilik.html" },
            { emoji: "✅", label: "Template Approval Pesanan",            file: "ApprovalPesanan.html" },
        ];

        /* ─── Auth ─── */
        const STORED_HASH = "3b9f22265fb9a4281cc63324eb6507ded33a35dfe65b84e7dac044447fb45f82";

        async function h(m) {
            const b  = new TextEncoder().encode(m);
            const hb = await crypto.subtle.digest('SHA-256', b);
            return Array.from(new Uint8Array(hb)).map(x => x.toString(16).padStart(2,'0')).join('');
        }

        async function checkPassword() {
            const p = document.getElementById("password");
            const e = document.getElementById("errorMessage");
            if ((await h(p.value)) === STORED_HASH) {
                sessionStorage.setItem("auth", "true");
                sessionStorage.setItem("exp", Date.now() + 24*60*60*1000);
                showApp();
            } else {
                e.textContent = "❌ Password salah! Silakan coba lagi.";
                e.classList.add("show");
                p.value = ""; p.focus();
                p.style.animation = "shake 0.5s";
                setTimeout(() => p.style.animation = "", 500);
                setTimeout(() => e.classList.remove("show"), 3000);
            }
        }

        function checkAuth() {
            const auth = sessionStorage.getItem("auth");
            const exp  = sessionStorage.getItem("exp");
            if (auth === "true" && exp && Date.now() < parseInt(exp)) showApp();
        }

        /* ─── App init ─── */
        function showApp() {
            document.querySelector(".password-container").style.display = "none";
            const app = document.getElementById("app");
            app.style.display = "block";
            app.classList.add("show");
            buildMenu();
        }

        /* ─── Build menu buttons dari MENU_ITEMS ─── */
        function buildMenu() {
            const grid = document.getElementById("links-grid");
            grid.innerHTML = "";
            MENU_ITEMS.forEach(item => {
                const btn = document.createElement("button");
                btn.className = "menu-btn";
                btn.innerHTML = `<span class="emoji">${item.emoji}</span><span class="text">${item.label}</span>`;
                btn.addEventListener("click", () => openPage(item.file, item.label));
                grid.appendChild(btn);
            });
        }

        /* ─── SPA navigation — Opsi C: per-page iframe, hide/show ─── */

        // Map: file → <iframe> element
        const iframeCache = {};
        let activeFile = null;

        function openPage(file, title) {
            document.getElementById("menu-view").style.display = "none";
            document.getElementById("content-view").classList.add("show");
            document.getElementById("page-title").textContent = title;
            document.body.classList.add("page-open"); // kunci scroll body

            // Sembunyikan iframe yang sedang tampil
            if (activeFile && iframeCache[activeFile]) {
                iframeCache[activeFile].style.display = "none";
            }

            if (iframeCache[file]) {
                // Pernah dibuka → tampilkan kembali, semua isian masih ada
                iframeCache[file].style.display = "block";
            } else {
                // Pertama kali → buat iframe baru
                const iframe     = document.createElement("iframe");
                iframe.src       = file;
                iframe.title     = title;
                iframe.onload    = () => {
                    try {
                        // Tinggi iframe mengikuti konten agar container bisa scroll
                        const body = iframe.contentDocument.body;
                        iframe.style.height = Math.max(body.scrollHeight, body.offsetHeight, 500) + "px";
                    } catch(e) {
                        iframe.style.height = "100%";
                    }
                };
                document.getElementById("iframe-container").appendChild(iframe);
                iframeCache[file] = iframe;
            }

            activeFile = file;
            // History API: Back browser → kembali ke menu
            history.pushState({ page: file, title }, "", `#${encodeURIComponent(file)}`);
        }

        function goBack() {
            document.getElementById("content-view").classList.remove("show");
            document.getElementById("menu-view").style.display = "block";
            document.body.classList.remove("page-open"); // lepas kunci scroll body
            // Sembunyikan saja — state di iframe tetap hidup
            if (activeFile && iframeCache[activeFile]) {
                iframeCache[activeFile].style.display = "none";
            }
            activeFile = null;
            history.replaceState(null, "", window.location.pathname);
        }

        /* ─── Boot ─── */
        document.addEventListener('DOMContentLoaded', () => {
            checkAuth();
            document.getElementById("password").addEventListener("keypress", e => {
                if (e.key === "Enter") { e.preventDefault(); checkPassword(); }
            });
            document.getElementById("back-btn").addEventListener("click", goBack);

            // Back button browser
            window.addEventListener("popstate", () => {
                if (document.getElementById("content-view").classList.contains("show")) goBack();
            });

            if (document.querySelector(".password-container").style.display !== "none") {
                document.getElementById("password").focus();
            }
        });
    </script>
</head>
<body>

    <!-- PASSWORD SCREEN -->
    <div class="password-container">
        <div class="password-header">
            <h2>🔒 Silakan Masukkan Password</h2>
        </div>
        <div class="password-content">
            <input type="password" id="password" placeholder="Masukkan password" autofocus>
            <div id="errorMessage" class="error-message"></div>
            <button class="password-button" onclick="checkPassword()">Masuk</button>
        </div>
    </div>

    <!-- MAIN APP -->
    <div id="app">

        <!-- MENU VIEW -->
        <div id="menu-view">
            <div class="header">
                <h1>Utilities</h1>
				<h2>PAKTJIP Digital Printing</h2>
            </div>
            <div class="content">
                <div id="links-grid" class="links-grid">
                    <!-- Diisi oleh buildMenu() -->
                </div>
                <div class="coming-soon">
                    <p>✨ More to coming soon! ✨</p>
                </div>
            </div>
            <footer>
                <strong>Copyright © 2026 PAKTJIP Digital Printing</strong><br>
                Vibe Coded by Lukas Ardianto using Claude AI
            </footer>
        </div>

        <!-- CONTENT VIEW -->
        <div id="content-view">
            <div class="content-topbar">
                <button id="back-btn">← Kembali</button>
                <span id="page-title"></span>
            </div>
            <div id="iframe-container"></div>
        </div>

    </div>

</body>
</html>
